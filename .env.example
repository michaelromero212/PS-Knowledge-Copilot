# PS Knowledge Copilot - Environment Variables
# Copy this file to .env and fill in your values

# ============= SECURITY WARNING =============
# NEVER commit your .env file to version control!
# NEVER share API keys in code, commits, or public repositories!
# Rotate keys immediately if accidentally exposed!

# ============= LLM Providers =============
# Choose one or more providers. Gemini is the default provider.

# Google Gemini (default provider, uses gemini-2.5-flash-lite)
# Get your key from: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# Optional: override the Gemini model (default: gemini-2.5-flash-lite).
# Note: gemini-2.5-flash has only ~20 free requests/day; flash-lite is far more generous.
# GEMINI_MODEL=gemini-2.5-flash-lite

# OpenAI (for GPT-4o-mini)
OPENAI_API_KEY=your_openai_api_key_here

# Anthropic (for Claude)
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Hugging Face (for Inference API)
# Get your key from: https://huggingface.co/settings/tokens
HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# ============= Optional Settings =============
# Default LLM provider: gemini, openai, anthropic, huggingface_local, or huggingface_api
# LLM_PROVIDER=gemini

# ChromaDB persistence path (default: ./data/chroma_db)
# CHROMA_DB_PATH=./data/chroma_db

# API Key for admin endpoints (generate a secure random key)
# API_KEY=your_secure_random_api_key_here
